# copy this to .env and fill in real values. .env is gitignored.

# required for Panel 2 stance classification
ANTHROPIC_API_KEY=

# optional - live reddit pulls. create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=agrcomm-discourse-shift/0.1 by u/yourname

# optional - 2010-2016 news baseline. academic access at https://mediacloud.org
MEDIACLOUD_API_KEY=

# optional - deep historical GDELT via BigQuery. otherwise DOC 2.0 API is used (2017+)
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT=
